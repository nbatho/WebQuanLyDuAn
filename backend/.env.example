PORT = 5001
HOST=0.0.0.0
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Supabase PostgreSQL (Transaction/Session pooler is recommended for Docker)
DB_HOST=your-project-pooler.supabase.com
DB_PORT=5432
DB_USER=postgres.your-project-ref
DB_PASSWORD=your_supabase_database_password
DB_NAME=postgres
DB_SSL=true

# Alternatively, the backend also accepts Supabase's connection string:
# DATABASE_URL=postgresql://postgres.project-ref:password@host:5432/postgres

RESEND_API_KEY = 'resend_api'
GROQ_API_KEY='groq_api_key'

ACCESS_TOKEN_SECRET = 'access_token_secret'
EMAIL_TOKEN_SECRET='email_token_secret'

GOOGLE_CLIENT_ID='google_client_id'
